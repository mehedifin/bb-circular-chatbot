# --- Authentication (required) ---
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=replace-with-a-long-random-secret

# Demo users for the credentials provider: "email:password,email:password"
# Replace with a real user store / SSO before production.
DEMO_USERS=demo@bb-circulars.app:demo1234

# --- AI (recommended) ---
# Vercel AI Gateway key — https://vercel.com/docs/ai-gateway
# Without it the app still works: retrieval runs, answers fall back to excerpts.
AI_GATEWAY_API_KEY=

# Optional model overrides (AI Gateway model ids)
CHAT_MODEL=anthropic/claude-sonnet-4.6
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Ingestion (scripts/) ---
# Free OCR for scanned PDFs — get a free key at https://ocr.space/ocrapi
# The "helloworld" demo key works for testing with tight rate limits.
OCR_SPACE_API_KEY=helloworld
